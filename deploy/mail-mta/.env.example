# Copier vers .env sur le VPS — ne pas versionner .env

# Domaine alias (réception) — placeholder
MAIL_ALIAS_DOMAIN=alias.example.ovh

# Hostname annoncé par Postfix (doit correspondre au PTR / cert TLS)
MTA_HOSTNAME=mail.example.ovh

# Domaines autorisés en envoi (soumission 587) — séparés par des espaces
ALLOWED_SENDER_DOMAINS=${MAIL_ALIAS_DOMAIN}

# Relais sortant optionnel (ex. smtp du fournisseur principal)
# RELAYHOST=[smtp.example.ovh]:587
# RELAYHOST_USERNAME=
# RELAYHOST_PASSWORD=

# OpenDKIM
DKIM_SELECTOR=cloudity

# Ports hôte (obligatoires — pas de défaut dans compose)
SMTP_PORT=25
SUBMISSION_PORT=587
