# Copier vers .env sur le VPS — ne pas versionner .env (FQDN/IP réels interdits dans Git).

# Domaine alias (réception SMTP entrant)
MAIL_ALIAS_DOMAIN=alias.example.invalid
MADDY_DOMAIN=alias.example.invalid
MADDY_HOSTNAME=mail.alias.example.invalid

# Résolution alias Cloudity (même token que mail-directory-service)
MAIL_DIRECTORY_URL=http://mail-directory-service:8050
MTA_INTERNAL_TOKEN=change_me_mta_internal_token_min_32_chars

# Postfix (docker-compose.yml)
MTA_HOSTNAME=mail.alias.example.invalid
ALLOWED_SENDER_DOMAINS=${MAIL_ALIAS_DOMAIN}
DKIM_SELECTOR=cloudity
RELAYHOST=
RELAYHOST_USERNAME=
RELAYHOST_PASSWORD=

# Ports hôte — prod VPS : 25 / 587 ; local : voir .env.local.example (2525 / 2587)
SMTP_PORT=25
SUBMISSION_PORT=587
IMAP_PORT=143
SMTPS_PORT=465
IMAPS_PORT=993

# Maddy VPS (docker-compose.maddy.yml)
MADDY_DOCKER_NETWORK=cloudity-mta
MADDY_CERTS_PATH=./certs
