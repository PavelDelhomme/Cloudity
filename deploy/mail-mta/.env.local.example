# Copier vers deploy/mail-mta/.env (gitignored) — tests MTA locaux
# Ne pas committer de FQDN/IP réels.

MAIL_ALIAS_DOMAIN=alias.example.invalid
MADDY_HOSTNAME=mail.alias.example.invalid
MADDY_DOMAIN=alias.example.invalid

MAIL_DIRECTORY_URL=http://host.docker.internal:6050
MTA_INTERNAL_TOKEN=change_me_mta_internal_token_min_32_chars

SMTP_PORT=2525
SUBMISSION_PORT=2587
IMAP_PORT=2143
SMTPS_PORT=2465
IMAPS_PORT=2993

MADDY_DOCKER_NETWORK=cloudity-mta-local
MADDY_CERTS_PATH=./certs
