# =============================================================================
# Cloudity — variables stack Portainer (MODÈLE — pas de vrais secrets)
# Copier dans Portainer → Stack cloudity-stack → Environment variables (advanced)
# Ou sur le VPS : deploy/portainer/stack.env (gitignored) référencé si besoin
# Générer des valeurs : make secrets-print  (sur machine de dev)
# =============================================================================

# --- Socle données ---
POSTGRES_USER=cloudity_admin
POSTGRES_PASSWORD=REMPLACER_openssl_rand_hex_24
POSTGRES_DB=cloudity
REDIS_PASSWORD=REMPLACER_openssl_rand_hex_24

# --- Auth / API ---
JWT_SECRET=REMPLACER_openssl_rand_hex_32
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
ACCESS_TOKEN_DURATION_MINUTES=60
PERFORMANCE_INGEST_TOKEN=REMPLACER_openssl_rand_hex_32

# --- Environnement runtime ---
GO_ENV=production
NODE_ENV=production
BUILD_TARGET=production
LOG_LEVEL=info
LOG_FORMAT=json

# --- URLs publiques (adapter <DOMAIN> — ou générer via make env-prod DOMAIN=…) ---
# Sur le PC : make env-prod DOMAIN=cloudity.example && make portainer-env
CLOUDITY_PUBLIC_HOST=cloudity.example
CLOUDITY_PUBLIC_PROTO=https
CLOUDITY_PUBLIC_API_HOST=api.cloudity.example
CLOUDITY_PUBLIC_OMIT_PORTS=true
# CORS_ORIGINS_EXTRA=https://admin.cloudity.example
VITE_API_URL=https://api.cloudity.example
CORS_ORIGINS=https://cloudity.example,https://admin.cloudity.example
CORS_ALLOW_LAN=false
CLOUDITY_MOBILE_GATEWAY_URL=https://api.cloudity.example

# --- WebAuthn (prod) ---
WEBAUTHN_RP_ID=cloudity.example
WEBAUTHN_RP_NAME=Cloudity
WEBAUTHN_ORIGINS=https://cloudity.example,https://admin.cloudity.example

# --- Mail chiffrement ---
MAIL_PASSWORD_ENCRYPTION_KEY=REMPLACER_64_hex_ou_make_ensure_mail_encryption_key
ALIAS_ENCRYPTION_KEY=REMPLACER_base64_32_octets

# --- Ports hôte (VPS : laisser série 60XX ou ne pas exposer postgres/redis publiquement) ---
PORT_DASHBOARD=6001
PORT_GATEWAY=6002
PORT_AUTH=6003
PORT_ADMIN=6004
PORT_MAIL_DIRECTORY=6005
PORT_PASS_MGR=6006
PORT_CALENDAR=6007
PORT_NOTES=6008
PORT_TASKS=6009
PORT_DRIVE=6010
PORT_CONTACTS=6011
PORT_PHOTOS=6012
PORT_POSTGRES=6042
PORT_REDIS=6079

# --- mTLS interne (défaut prod simple) ---
MTLS_MODE=off

# --- TOTP ---
TOTP_ISSUER=Cloudity
TOTP_PERIOD=30

# --- Rate limit ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# --- Seed admin (première install uniquement — changer le mot de passe après) ---
# SEED_ADMIN_EMAIL=admin@cloudity.local
# SEED_ADMIN_PASSWORD=ChangerApresPremiereConnexion

# --- NE PAS en prod ---
# CLOUDITY_ALLOW_E2E_BOOTSTRAP=1
