go 1.25.0

// Workspace mono-repo : permet aux outils Go locaux (IDE, `go build` à la
// racine, `go test ./...`) de résoudre les imports inter-modules sans publier
// internalsec sur un dépôt distant.
//
// IMPORTANT : Docker build de chaque service utilise `./backend` comme contexte
// et IGNORE go.work (fichier racine uniquement). Les `go.mod` des services
// gardent `replace … => ./internalsec` pour l’image (COPY internalsec → /app/internalsec).
//
// En local, `replace` dans go.work pointe vers `./backend/internalsec` (module
// hors `use` pour éviter le conflit api-gateway vs auth-service).

use (
	./backend/api-gateway
	./backend/auth-service
	./backend/calendar-service
	./backend/contacts-service
	./backend/drive-service
	./backend/mail-directory-service
	./backend/notes-service
	./backend/passwords-service
	./backend/photos-service
	./backend/pkg/dbpin
	./backend/tasks-service
)

replace github.com/pavel/cloudity/internalsec => ./backend/internalsec
