FROM golang:1.25-alpine

WORKDIR /app
ENV GOTOOLCHAIN=auto

RUN apk add --no-cache git wget

RUN go install github.com/cosmtrek/air@v1.42.0

# Context = ./backend (voir docker-compose.yml). go.mod replace => ../internalsec → /internalsec
COPY internalsec /internalsec
COPY auth-service/go.mod auth-service/go.sum ./
RUN go mod download

COPY auth-service/ ./

EXPOSE 8081

CMD ["air", "-c", ".air.toml"]
