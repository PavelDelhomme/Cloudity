{
  "name": "cloudity-frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo frontend : @cloudity/web, @cloudity/ui (design system) et @cloudity/shared.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @cloudity/web",
    "build": "npm run build -w @cloudity/web",
    "test": "npm run test -w @cloudity/web",
    "lint": "npm run lint -w @cloudity/web",
    "preview": "npm run preview -w @cloudity/web"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "jsdom": "^29.1.1"
  }
}
