{
  "global": {
    "nosec": true,
    "audit": true,
    "show-ignored": false
  },
  "exclude-rules": [
    {
      "path": ".*",
      "rules": ["G104"]
    },
    {
      "path": "cmd/.*",
      "rules": ["G114", "G706"]
    },
    {
      "path": "main\\.go$",
