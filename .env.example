# PostgreSQL Configuration
POSTGRES_USER=cloudity_admin
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=cloudity

# Redis Configuration
REDIS_PASSWORD=change_me_redis_password

# JWT Configuration
JWT_SECRET=change_me_super_secret_jwt_key_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
# auth-service : durée du JWT d’accès en minutes (5–1440). Défaut dans docker-compose : 60. Refresh token 30 j.
# ACCESS_TOKEN_DURATION_MINUTES=60

# Performance pipeline ingestion (gateway + admin-service).
# OBLIGATOIRE en prod : sans valeur, POST /admin/performance/pipeline-run renvoie 503.
# Générer : `make secrets` (ou `openssl rand -hex 32`).
PERFORMANCE_INGEST_TOKEN=dev_perf_ingest_change_me

# Service URLs (usage interne Docker)
AUTH_SERVICE_URL=http://auth-service:8081
ADMIN_SERVICE_URL=http://admin-service:8082
API_GATEWAY_URL=http://api-gateway:8000

# Environment
NODE_ENV=development
BUILD_TARGET=dev

# === Ports hôte → conteneurs (docker-compose.yml) =====================
# Défauts = série actuelle (6001 dashboard, 6042 postgres, 605x microservices, 6079 redis, 608x gateway/auth/admin/outils dev).
# Pour une série 6001, 6002, … : surcharger ici puis aligner CORS / WEBAUTHN_ORIGINS / VITE_API_URL si besoin.
# Voir docs/operations/PORTS-HOTES.md
# PORT_POSTGRES=6042
# PORT_REDIS=6079
# PORT_AUTH=6081
# PORT_GATEWAY=6080
# PORT_ADMIN=6082
# PORT_MAIL_DIRECTORY=6050
# PORT_CALENDAR=6052
# PORT_NOTES=6053
# PORT_TASKS=6054
# PORT_DRIVE=6055
# PORT_CONTACTS=6056
# PORT_DASHBOARD=6001
# PORT_ADMINER=6083
# PORT_REDIS_COMMANDER=6084
# =====================================================================

# Bootstrap session E2E/CI (TEST-AUTH-01) — **auth-service** uniquement, **jamais** en prod
# (refus automatique si GO_ENV ou NODE_ENV = production). OTP jetable Redis, secret comparé en temps constant.
# CLOUDITY_ALLOW_E2E_BOOTSTRAP=1
# E2E_BOOTSTRAP_SECRET=remplacer_par_au_moins_32_caracteres_aleatoires
# E2E_BOOTSTRAP_OTP_TTL_SECONDS=120

# Frontend: URL de l'API (vide = requêtes relatives via proxy Vite). En Docker : http://localhost:6080
# Pour ouvrir l'app sur smartphone : mets l'IP de ta machine (ex. VITE_API_URL=http://192.168.1.5:6080), puis ouvre sur le téléphone http://<TON_IP>:6001
VITE_API_URL=

# 2FA
TOTP_ISSUER=Cloudity
TOTP_PERIOD=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# CORS (origines autorisées par l'API gateway)
# Liste fixe si CORS_ALLOW_LAN non utilisé : CORS_ORIGINS=http://localhost:6001,http://localhost:5173
# HTTPS-first : ajouter https://app.cloudity.local pour le mode `make up-tls`.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:6001,https://app.cloudity.local
# Autoriser tout le réseau local (localhost + 192.168.x.x, 10.x.x.x, 172.16–31.x.x) pour ouvrir sur smartphone
CORS_ALLOW_LAN=true

# === HTTPS / mTLS interne ============================================
# Voir docs/securite/MTLS-INTERNE.md et docs/securite/AUDIT-SECURITE.md § HTTPS partout.
# `off` = HTTP plain (legacy). `permissive` = TLS 1.3 exigé, cert client optionnel.
# `strict` = TLS 1.3 + cert client obligatoire (cible Zero Trust).
MTLS_MODE=off
MTLS_CERT_FILE=/run/step/cert.pem
MTLS_KEY_FILE=/run/step/key.pem
MTLS_CA_FILE=/run/step/ca.pem
# Liste blanche d'identités SPIFFE acceptées (séparées par virgule).
# Ex : MTLS_ALLOWED_PEERS=spiffe://cloudity.local/ns/default/sa/api-gateway
MTLS_ALLOWED_PEERS=

# Redis TLS (auth-service go-redis) — activer avec docker-compose.https.yml
# REDIS_TLS=1
# REDIS_TLS_CA=/run/step/ca.pem
# =====================================================================

# === WebAuthn / passkeys (Phase W1, /4dm1n) =========================
# Voir docs/securite/WEBAUTHN-PLAN.md § 6 — défauts adaptés au dev local.
# En prod : RP_ID = host du domaine admin (sans schéma ni port).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Cloudity Admin
WEBAUTHN_ORIGINS=http://localhost:6001,http://localhost:5173
# =====================================================================

# Mail – OAuth Google (Gmail sans mot de passe d'application)
# Voir docs/produit/MAIL-GMAIL-OAUTH.md pour la configuration pas à pas.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:6080/mail/me/oauth/google/callback
# MAIL_OAUTH_FRONTEND_URL=http://localhost:6001

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
