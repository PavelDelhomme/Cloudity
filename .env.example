# =============================================================================
# Cloudity — modèle d'environnement (NE PAS committer .env avec de vrais secrets)
#
# ★ GUIDE MAÎTRE (local + mobile LAN + prod Portainer/NPM) :
#   docs/operations/GUIDE-COMPLET-DEPLOIEMENT-ET-TESTS.md
#
# Guide détaillé : docs/operations/ENV-GENERATION.md
# Déploiement par service : docs/operations/DEPLOIEMENT-PAR-SERVICE.md
# mTLS (TLS entre microservices) : docs/securite/MTLS-INTERNE.md § 0
# Alias mail (Pass ↔ Mail) : docs/produit/MAIL-ALIAS-VISION.md + MAIL-ALIAS-DEMARRAGE.md
# =============================================================================
#
# Génération rapide :
#   make secrets                    # nouveau .env complet (échoue si .env existe)
#   make ensure-mail-encryption-key # clé IMAP seule
#   make ensure-alias-encryption-key
#   make secrets-print              # afficher sans écrire (copier vers Portainer)
#
# =============================================================================

# PostgreSQL Configuration
POSTGRES_USER=cloudity_admin
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=cloudity

# Redis Configuration
REDIS_PASSWORD=change_me_redis_password

# JWT Configuration
JWT_SECRET=change_me_super_secret_jwt_key_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
# auth-service : durée du JWT d’accès en minutes (5–1440). Défaut dans docker-compose : 60. Refresh token 30 j.
# ACCESS_TOKEN_DURATION_MINUTES=60

# Performance pipeline ingestion (gateway + admin-service).
# OBLIGATOIRE en prod : sans valeur, POST /admin/performance/pipeline-run renvoie 503.
# Générer : `make secrets` (ou `openssl rand -hex 32`).
PERFORMANCE_INGEST_TOKEN=dev_perf_ingest_change_me

# Service URLs (usage interne Docker)
AUTH_SERVICE_URL=http://auth-service:8081
ADMIN_SERVICE_URL=http://admin-service:8082
API_GATEWAY_URL=http://api-gateway:8000

# Environment
NODE_ENV=development
BUILD_TARGET=dev

# === Ports hôte → conteneurs (docker-compose.yml) — série séquentielle PORT-ORG-01 ===
# 6001 web · 6002 gateway · 6003 auth · 6004 admin · 6005–6012 microservices · 6042 postgres · 6079 redis
# Migration depuis ancienne série (6080 gateway…) : make ports-sequential
# Voir docs/operations/PORTS-HOTES.md
PORT_DASHBOARD=6001
PORT_GATEWAY=6002
# Compte admin local (make seed-admin) — email réel recommandé en dev perso :
SEED_ADMIN_EMAIL=mail@example.com
# Mot de passe du compte seed (local uniquement — jamais commité).
# Après changement : make seed-admin-reset (recrée le user avec le nouveau mot de passe).
SEED_ADMIN_PASSWORD=
PORT_AUTH=6003
PORT_ADMIN=6004
PORT_MAIL_DIRECTORY=6005
PORT_PASS_MGR=6006
PORT_CALENDAR=6007
PORT_NOTES=6008
PORT_TASKS=6009
PORT_DRIVE=6010
PORT_CONTACTS=6011
PORT_PHOTOS=6012
PORT_POSTGRES=6042
PORT_REDIS=6079
PORT_ADMINER=6083
PORT_REDIS_COMMANDER=6084
# =====================================================================

# Bootstrap session E2E/CI (TEST-AUTH-01) — **auth-service** uniquement, **jamais** en prod
# (refus automatique si GO_ENV ou NODE_ENV = production). OTP jetable Redis, secret comparé en temps constant.
# CLOUDITY_ALLOW_E2E_BOOTSTRAP=1
# E2E_BOOTSTRAP_SECRET=remplacer_par_au_moins_32_caracteres_aleatoires
# E2E_BOOTSTRAP_OTP_TTL_SECONDS=120

# Frontend: URL publique de l'API gateway (vide = requêtes relatives via proxy Vite).
# Dev local/LAN : HTTP direct sur le port API gateway (ex. http://192.168.1.5:6002).
# Préprod/prod : HTTPS obligatoire derrière reverse-proxy/LB (ex. https://api.cloudity.example).
# URL du dashboard web (PORT_WEB, défaut 6001). En dev Vite, les appels API passent par le proxy
# same-origin si vous ouvrez http://localhost:6001 ou http://cloudity.localhost:6001 (pas de CORS).
# VITE_API_URL sert surtout au build prod et aux accès LAN directs (http://<IP>:6001).
VITE_API_URL=http://localhost:6002
# Apps Flutter (Drive/Mail/Photos/Pass) : injecté par scripts/mobile/run-mobile.sh via --dart-define=CLOUDITY_GATEWAY_URL.
# Dev local/LAN : http://<IP_PC>:6002 ou http://127.0.0.1:6002 avec `adb reverse tcp:6002 tcp:6002`.
# Préprod/prod : HTTPS public du gateway, ex. https://api.cloudity.example (certificat valide côté téléphone).
# Ne pas utiliser l'URL du front :6001 ici : le mobile parle à l'API gateway.
CLOUDITY_MOBILE_GATEWAY_URL=http://127.0.0.1:6002

# Rapports crash / feedback mobile (gateway) — fichiers JSON sous ce dossier (volume Docker en prod).
MOBILE_CRASH_LOG_DIR=storage/mobile-crashes

# 2FA
TOTP_ISSUER=Cloudity
TOTP_PERIOD=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# CORS (origines navigateur autorisées par l'API gateway ; les apps mobiles natives ne passent pas par CORS)
# Liste fixe si CORS_ALLOW_LAN non utilisé : CORS_ORIGINS=http://localhost:6001,http://localhost:5173
# HTTPS-first : ajouter l'origine du front HTTPS (ex. https://app.cloudity.local ou https://cloudity.example).
# Inclure https://cloudity.localhost:6001 si tu utilises ce host (CORS_ALLOW_LAN couvre *.localhost en dev).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:6001,https://app.cloudity.local,https://cloudity.localhost:6001,http://192.168.1.5:6001,https://cloudity.example
# Autoriser tout le réseau local (localhost + 192.168.x.x, 10.x.x.x, 172.16–31.x.x) pour ouvrir sur smartphone en dev.
# En préprod/prod : CORS_ALLOW_LAN=false et CORS_ORIGINS=https://cloudity.<domaine>.
CORS_ALLOW_LAN=true

# === HTTPS / mTLS interne ============================================
# Qu'est-ce que mTLS ? → docs/securite/MTLS-INTERNE.md § 0 (TLS navigateur ≠ mTLS entre services).
# `off` = HTTP plain entre conteneurs (défaut dev). `permissive` = TLS 1.3, cert client optionnel.
# `strict` = TLS 1.3 + cert client obligatoire (cible Zero Trust). Pas requis pour Mail/Pass au quotidien.
MTLS_MODE=off
MTLS_CERT_FILE=/run/step/cert.pem
MTLS_KEY_FILE=/run/step/key.pem
MTLS_CA_FILE=/run/step/ca.pem
# Liste blanche d'identités SPIFFE acceptées (séparées par virgule).
# Ex : MTLS_ALLOWED_PEERS=spiffe://cloudity.local/ns/default/sa/api-gateway
MTLS_ALLOWED_PEERS=

# Redis TLS (auth-service go-redis) — activer avec docker-compose.https.yml
# REDIS_TLS=1
# REDIS_TLS_CA=/run/step/ca.pem
# =====================================================================

# === WebAuthn / passkeys (Phase W1, /4dm1n) =========================
# Voir docs/securite/WEBAUTHN-PLAN.md § 6 — défauts adaptés au dev local.
# En prod : RP_ID = host du domaine admin (sans schéma ni port).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Cloudity Admin"
WEBAUTHN_ORIGINS=http://localhost:6001,http://localhost:5173
# =====================================================================

# Mail – OAuth Google (Gmail sans mot de passe d'application)
# Voir docs/produit/MAIL-GMAIL-OAUTH.md pour la configuration pas à pas.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:6002/mail/me/oauth/google/callback
# MAIL_OAUTH_FRONTEND_URL=http://localhost:6001

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# === Chiffrement Mail / alias (mail-directory-service) ==================
# Vision produit alias (Pass → example@alias.ton-domaine) :
#   docs/produit/MAIL-ALIAS-VISION.md
#
# MAIL_PASSWORD_ENCRYPTION_KEY — OPÉRATIONNEL : AES-GCM des MDP IMAP/SMTP en base.
# Obligatoire dès qu’une boîte est connectée. Rotation = ré-enregistrer chaque MDP boîte.
# Génération : `make ensure-mail-encryption-key` ou `openssl rand -hex 32` (64 hex).
MAIL_PASSWORD_ENCRYPTION_KEY=

# Anti-spam Cloudity (mail-directory-service) — triage post-sync réception → spam
# 1 = actif (défaut) ; 0 pour désactiver. Seuil 0–100 (défaut 52, aligné UI).
MAIL_SPAM_AUTO_TRIAGE_ENABLED=1
MAIL_SPAM_AUTO_TRIAGE_THRESHOLD=52

# ALIAS_ENCRYPTION_KEY — PRÉSENT dans Compose/VPS, PAS ENCORE LU par le Go :
# réservé provision alias (API OVH, tokens) — BACKLOG MAIL-ALIAS-KEY-01.
# Génération : `make ensure-alias-encryption-key` ou `openssl rand -base64 32`.
ALIAS_ENCRYPTION_KEY=

# --- Alias jetables (MAIL-ALIAS-03) ---
# Domaine principal : suffixe par défaut alias.<domaine> + validation stricte à la création.
# MAIL_PRIMARY_DOMAIN=domain.ovh
# Suffixe complet après @ (optionnel ; sinon alias.<MAIL_PRIMARY_DOMAIN>).
# MAIL_ALIAS_SUBDOMAIN=alias.domain.ovh
# Option provision OVH sans UI (futur) :
# OVH_API_APPLICATION_KEY=
# OVH_API_APPLICATION_SECRET=
# OVH_API_CONSUMER_KEY=
# =====================================================================

# === Mail alias (MTA) ============================================
# Voir docs/produit/MAIL-ALIAS-MTA.md
# MTA_INTERNAL_TOKEN=
# MAIL_ALIAS_DOMAIN=alias.domain.ovh
# MAIL_ALIAS_PORT=2525
# =====================================================================
