# PostgreSQL Configuration
POSTGRES_USER=cloudity_admin
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=cloudity

# Redis Configuration
REDIS_PASSWORD=change_me_redis_password

# JWT Configuration
JWT_SECRET=change_me_super_secret_jwt_key_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Service URLs (usage interne Docker)
AUTH_SERVICE_URL=http://auth-service:8081
ADMIN_SERVICE_URL=http://admin-service:8082
API_GATEWAY_URL=http://api-gateway:8000

# Environment
NODE_ENV=development
BUILD_TARGET=dev

# Frontend: URL de l'API (vide = requêtes relatives via proxy Vite). En Docker : http://localhost:6080 (Chrome bloque le port 6000, ERR_UNSAFE_PORT)
VITE_API_URL=

# 2FA
TOTP_ISSUER=Cloudity
TOTP_PERIOD=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# CORS (origines autorisées par l'API gateway)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:6001

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
