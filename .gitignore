# Rapports de tests
reports/
**/test-results-drive-loop.json

# Exports de profiling (Chrome Performance, React DevTools Profiler) — souvent volumineux ; voir docs/operations/PERFORMANCES.md §8
profiling-data*.json
Trace-*.json
Trace-*.tgz

# Dépendances et artefacts de build (ne pas versionner)
node_modules/
dist/
**/dist/
# Cache pré-bundle Vite (généré localement / dans Docker — jamais versionner)
**/.vite/
backend/api-gateway/tmp/
# Binaires Go produits par `go build` dans chaque service (mêmes nom que le dossier)
backend/auth-service/auth-service
backend/api-gateway/api-gateway
backend/calendar-service/calendar-service
backend/contacts-service/contacts-service
backend/drive-service/drive-service
backend/mail-directory-service/mail-directory-service
backend/notes-service/notes-service
backend/passwords-service/passwords-service
backend/photos-service/photos-service
backend/tasks-service/tasks-service
# Logs internes Air / outillage
backend/*/tmp/build-errors.log
backend/*/tmp/main

# Fichiers .html de test ou brouillons (création rapide de docs)
test.html
*.tmp.html

# Préférences locales Cursor IDE (ne pas versionner)
.cursor/

# Env local (secrets, ne pas committer)
.env
deploy/mail-mta/.env
.env.local
.env.dev
.env.prod
.env.production
.env.staging
.env.test
.env.*.local
.env.*

# Garde-fou : autoriser uniquement les exemples documentés.
!.env.example
!deploy/mail-mta/.env.local.example

# Certificats locaux (mkcert) — dev HTTPS
.certs/

# Clés privées et matériel cryptographique (jamais versionnés)
*.pem
*.key
*.p12
*.pfx
*.jks
*.crt
*_key.pem
*-key.pem
private*.pem
private_*.pem
public*.pem
public_*.pem
backend/auth-service/private*.pem
backend/auth-service/public*.pem
infrastructure/step-ca/secrets/*
!infrastructure/step-ca/secrets/.gitignore
!infrastructure/step-ca/secrets/.gitkeep
!infrastructure/step-ca/secrets/ca-password.example

# Certificats émis pour les services par step-ca (clés privées)
infrastructure/step-ca/issued/

# Dumps et backups
*.sql.gz
*.dump
*.bak
backups/

# Tokens applicatifs / fichiers de credentials
credentials.json
service-account*.json
google-credentials.json
*.token

# Clés RSA auth-service (générées par make setup ; private ne doit pas être versionné)
backend/auth-service/private.pem
# Clés Ed25519 auth-service (générées par auth-service au boot ; jamais versionnées —
# clés dev éphémères, regénérées à chaque setup propre).
backend/auth-service/private_ed25519.pem
backend/auth-service/public_ed25519.pem
# Build / cache auth-service
backend/auth-service/tmp/

# Dossier storage local (volumes Docker pour postgres/redis par défaut) — versionner seulement la notice.
storage/*
!storage/README.txt

# Profils ADB : artefacts runtime locaux (screenshots, dumps volumineux) — pas l'empreinte golden.
mobile/device-profiles/**/runtime/
